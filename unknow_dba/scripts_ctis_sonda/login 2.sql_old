SET SERVEROUTPUT ON
SET FEEDBACK ON
SET HEAD ON
SET LINES 160
SET LONG 900000000;
SET PAGESIZE 45000
SET SQLPROMPT "_USER'@'_CONNECT_IDENTIFIER : SQL> "
SET TIME ON
SET TIMING ON
SET VERIFY OFF
SET TRIMOUT OFF
SET TRIMSPOOL OFF
COL OWNER FORMAT A10
COL TABLE_NAME FORMAT A30
COL CONSTRAINT_NAME FORMAT A30
COL NAME FORMAT A30
COL USERNAME FORMAT A20
